---
/**
 * WhatsAppFloat.astro — Botón flotante fijo WhatsApp.
 * Bottom-right, z-[80] (bajo el MobileNav overlay z-[90]).
 * Respeta safe-area (notch/home-bar en móvil con padding-bottom).
 * Icono SVG inline oficial WhatsApp, verde de marca.
 * Tooltip "Escríbenos" en hover.
 */
import { site } from "../../data/site";

/* Número limpio sin + ni espacios para wa.me */
const waNumber = site.whatsapp.replace(/\D/g, "");
const waHref = `https://wa.me/${waNumber}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<div
  class="fixed bottom-6 right-6 z-[80] flex items-end gap-2"
  style="padding-bottom: env(safe-area-inset-bottom, 0px);"
>
  {/* Tooltip "Escríbenos" — visible en hover via CSS */}
  <span
    class={[
      "tooltip-label",
      "mb-1 px-3 py-1.5 rounded-md text-xs font-medium",
      "bg-ink-soft border border-ink-line text-on-dark",
      "shadow-soft whitespace-nowrap",
      "opacity-0 translate-x-1",
      "transition-all duration-150 ease-out",
      "pointer-events-none",
      "select-none",
    ].join(" ")}
    aria-hidden="true"
  >
    Escríbenos
  </span>

  {/* Botón principal */}
  <a
    href={waHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escríbenos por WhatsApp"
    class="whatsapp-float-btn group"
  >
    {/* Halo / glow de fondo */}
    <span
      class="absolute inset-0 rounded-full bg-[#25D366]/20 scale-0 group-hover:scale-150 transition-transform duration-300 ease-out"
      aria-hidden="true"
    ></span>

    {/* Icono SVG WhatsApp */}
    <svg
      width="26"
      height="26"
      viewBox="0 0 24 24"
      fill="white"
      aria-hidden="true"
      class="relative z-10"
    >
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
    </svg>
  </a>
</div>

<style>
  /* Botón flotante */
  .whatsapp-float-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: #25D366;
    box-shadow:
      0 4px 16px -2px rgba(37, 211, 102, 0.45),
      0 2px 8px -2px rgba(0, 0, 0, 0.3);
    transition: transform 200ms ease-out, box-shadow 200ms ease-out;
    overflow: hidden;
    flex-shrink: 0;
  }

  .whatsapp-float-btn:hover {
    transform: scale(1.08);
    box-shadow:
      0 6px 24px -2px rgba(37, 211, 102, 0.6),
      0 2px 8px -2px rgba(0, 0, 0, 0.3);
  }

  .whatsapp-float-btn:focus-visible {
    outline: 2px solid #25D366;
    outline-offset: 3px;
  }

  /* Muestra tooltip en hover del contenedor */
  .whatsapp-float-btn:hover + .tooltip-label,
  div:has(.whatsapp-float-btn:hover) .tooltip-label,
  div:has(.whatsapp-float-btn:focus-visible) .tooltip-label {
    opacity: 1;
    transform: translateX(0);
  }

  /* Respeta reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .whatsapp-float-btn {
      transition: none;
    }
    .whatsapp-float-btn:hover {
      transform: none;
    }
  }
</style>

{/* Script inline: muestra el tooltip al hover del contenedor completo */}
<script>
  (() => {
    const container = document.currentScript?.previousElementSibling?.closest("div") ??
                      document.querySelector(".whatsapp-float-btn")?.closest("div[class*='fixed']");
    const btn = document.querySelector<HTMLAnchorElement>(".whatsapp-float-btn");
    const label = document.querySelector<HTMLSpanElement>(".tooltip-label");
    if (!btn || !label) return;

    /* Hover en el botón → mostrar tooltip via clase */
    btn.addEventListener("mouseenter", () => {
      label.style.opacity = "1";
      label.style.transform = "translateX(0)";
    });
    btn.addEventListener("mouseleave", () => {
      label.style.opacity = "0";
      label.style.transform = "translateX(4px)";
    });
    btn.addEventListener("focus", () => {
      label.style.opacity = "1";
      label.style.transform = "translateX(0)";
    });
    btn.addEventListener("blur", () => {
      label.style.opacity = "0";
      label.style.transform = "translateX(4px)";
    });
  })();
</script>
